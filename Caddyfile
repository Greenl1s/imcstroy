# SITE_ADDRESS берётся из .env
#
#   pribory.example.ru   → Caddy сам получит сертификат Let's Encrypt (HTTPS)
#   :80                  → работа по HTTP, для локальной сети без домена
#
# Фронтенд и API живут на одном адресе. Благодаря этому нет ни проблем с CORS,
# ни запрета браузера на обращение с HTTPS-страницы к HTTP-серверу.

{$SITE_ADDRESS} {
	encode gzip

	# Всё, что начинается с /api, уходит на Node
	handle /api/* {
		reverse_proxy api:3000
	}

	# Остальное — статические файлы приложения
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy same-origin
		-Server
	}

	log {
		output stdout
		format console
	}
}
