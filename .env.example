# Скопируйте этот файл в .env и заполните значения.
# .env содержит пароли — не добавляйте его в git!

# ---------- База данных ----------
POSTGRES_DB=pribory
POSTGRES_USER=pribory
# Придумайте длинный пароль, вручную его вводить не придётся
POSTGRES_PASSWORD=

# ---------- Ключ подписи токенов ----------
# Минимум 32 символа. Сгенерировать:  openssl rand -base64 48
# Если этот ключ утечёт — можно будет подделать вход под администратором.
JWT_SECRET=

# ---------- Первый администратор ----------
# Создаётся автоматически при первом запуске, если админов в базе нет.
# Минимум 8 символов. Смените пароль в интерфейсе после первого входа.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---------- Адрес сайта ----------
# Свой домен (Caddy сам выпустит сертификат HTTPS):
#   SITE_ADDRESS=pribory.example.ru
# Только локальная сеть, без домена (тогда работа по HTTP):
#   SITE_ADDRESS=:80
SITE_ADDRESS=:80

# Нужен только если фронтенд лежит на другом адресе (например, на GitHub Pages).
# При схеме из docker-compose (статику отдаёт тот же Caddy) оставьте пустым.
ALLOWED_ORIGINS=

# ---------- Файловый менеджер (files.вашдомен.ру) ----------
# Пароль администратора для веб-файлового менеджера. Логин — admin.
# Минимум 8 символов, придумайте свой.
FILES_ADMIN_PASSWORD=

# ---------- Просмотр Excel/Word/PowerPoint (office.вашдомен.ру) ----------
# Общий секретный ключ между файловым менеджером и OnlyOffice — оба должны
# знать один и тот же, иначе они не смогут проверить друг друга.
# Сгенерировать:  openssl rand -base64 32
ONLYOFFICE_JWT_SECRET=
